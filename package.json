{
  "name": "viberadar",
  "version": "0.3.171",
  "description": "Live module map with test coverage for vibecoding projects",
  "main": "./dist/cli.js",
  "bin": {
    "viberadar": "./viberadar.js"
  },
  "scripts": {
    "build": "tsc && node scripts/bundle-ui.js",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint:logs": "node scripts/lint-logs.js",
    "test:lint-logs": "node scripts/test-lint-logs.js"
  },
  "type": "commonjs",
  "keywords": [
    "vibe",
    "coverage",
    "modules",
    "cli",
    "dashboard"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist",
    "bin",
    "viberadar.js"
  ],
  "dependencies": {
    "chokidar": "^3.6.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.1",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
